venues:
  - venue_name: Ancienne Belgique
    start_url: https://www.abconcerts.be/en/agenda
    selectors:
      card: .content-card__list__row
      title: .content-card__title
      date: .content-card__media__label
      url: a
    date_parsing:
      type: format
      format: '%a %d %b %y'
    performer_strategy:
      split_by:
        - ' + '
        - ' & '
        - ' / '
  - venue_name: Trix
    start_url: https://www.trixonline.be/en/program/
    selectors:
      card: .program-list__item
      title: .program-list__artist
      date: time
      url: self
    date_parsing:
      type: format
      format: '%Y-%m-%d'
      attr: datetime
    performer_strategy:
      split_by:
        - ' + '
        - ' / '
  - venue_name: New Venue
    start_url: https://
    selectors:
      card: ''
      title: ''
      date: ''
      url: ''
    performer_strategy:
      split_by:
        - ' + '
        - ' / '
